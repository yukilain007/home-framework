{
  "$defs": {
    "Source": {
      "additionalProperties": false,
      "description": "Provenance supplied by a human-controlled authority file.",
      "properties": {
        "reference": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference"
        },
        "type": {
          "enum": [
            "human_authored",
            "human_reviewed",
            "verified_import"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "Source",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Stable, reviewed authority content.",
  "properties": {
    "content": {
      "minLength": 1,
      "title": "Content",
      "type": "string"
    },
    "created_at": {
      "format": "date",
      "title": "Created At",
      "type": "string"
    },
    "id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "const": "core",
      "title": "Kind",
      "type": "string"
    },
    "priority": {
      "default": 50,
      "maximum": 100,
      "minimum": 0,
      "title": "Priority",
      "type": "integer"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scope": {
      "items": {
        "maxLength": 64,
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
        "type": "string"
      },
      "title": "Scope",
      "type": "array"
    },
    "sensitivity": {
      "enum": [
        "public",
        "private",
        "secret"
      ],
      "title": "Sensitivity",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/Source"
    },
    "status": {
      "enum": [
        "active",
        "inactive",
        "archived"
      ],
      "title": "Status",
      "type": "string"
    },
    "updated_at": {
      "format": "date",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "id",
    "content",
    "status",
    "sensitivity",
    "scope",
    "source",
    "created_at",
    "updated_at",
    "kind"
  ],
  "title": "CoreDocument",
  "type": "object"
}
